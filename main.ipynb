"""
Parkinson's Disease Detection: Explainable Precision Diagnostics Pipeline
=========================================================================
Author : Subham Barman | Roll No: 2328209 | KIIT University
Guide  : Dr. Sricheta Parui

Report Pipeline (Chapter 5):
  1.  Load UCI Parkinson's TQWT dataset (pd_speech_features.csv)
  2.  Yeo-Johnson Power Transformation   (normalise non-Gaussian TQWT features)
  3.  LASSO L1 + RFECV Feature Selection  (754 → ~25-40 features)
  4.  Stratified 80/20 Train-Test Split
  5a. SVM-RBF  – Optuna Bayesian hyperparameter optimisation
  5b. Deep MLP – Optuna Bayesian hyperparameter optimisation
  6.  Platt Scaling (CalibratedClassifierCV) for probability calibration
  7.  Evaluation: Accuracy, AUC-ROC, Precision, Recall, F1, Brier Score
  8.  SHAP Interpretability: global beeswarm + per-patient waterfall plots
  9.  Save confusion matrix, ROC curve, SHAP summary as PNG files
"""

# ── Imports ───────────────────────────────────────────────────────────────────
import os
import sys
if hasattr(sys.stdout, 'reconfigure'):
    sys.stdout.reconfigure(encoding='utf-8')
import warnings
warnings.filterwarnings("ignore")

import numpy as np
import pandas as pd
import matplotlib
matplotlib.use("Agg")
import matplotlib.pyplot as plt

from sklearn.model_selection import (train_test_split, StratifiedKFold,
                                     cross_val_score)
from sklearn.preprocessing import PowerTransformer
from sklearn.feature_selection import VarianceThreshold, RFECV
from sklearn.linear_model import LassoCV
from sklearn.svm import SVC
from sklearn.neural_network import MLPClassifier
from sklearn.calibration import CalibratedClassifierCV, calibration_curve
from sklearn.metrics import (accuracy_score, roc_auc_score, precision_score,
                             recall_score, f1_score, brier_score_loss,
                             roc_curve, confusion_matrix, classification_report)

import optuna
optuna.logging.set_verbosity(optuna.logging.WARNING)

import shap

# ─────────────────────────────────────────────────────────────────────────────
# CONFIG
# ─────────────────────────────────────────────────────────────────────────────
DATA_PATH      = "parkinsons.csv"
MODEL_CHOICE   = "svm_rbf"   # "svm_rbf"  or  "deep_mlp"
N_OPTUNA_TRIALS = 50
RANDOM_STATE   = 42

# ─────────────────────────────────────────────────────────────────────────────
# 1. LOAD DATASET
# ─────────────────────────────────────────────────────────────────────────────
if not os.path.exists(DATA_PATH):
    raise FileNotFoundError(
        f"\nDataset not found at: {DATA_PATH}\n"
        "Download 'parkinsons.csv' from:\n"
        "  https://archive.ics.uci.edu/dataset/174/parkinsons\n"
        "and place it in the same directory as this script."
    )

df = pd.read_csv(DATA_PATH, sep=",")
print(f"Dataset loaded  →  {df.shape[0]} rows × {df.shape[1]} columns")

TARGET = "status"
y = df[TARGET].values.astype(int)
X = df.drop(columns=[TARGET]).select_dtypes(include=[np.number])
X = X.fillna(X.median())
feature_names_raw = list(X.columns)

print(f"Raw features: {X.shape[1]}")
print(f"Class distribution: {dict(zip(*np.unique(y, return_counts=True)))}")

# ─────────────────────────────────────────────────────────────────────────────
# 2. STRATIFIED TRAIN/TEST SPLIT  (done first – preprocessing fitted on train)
# ─────────────────────────────────────────────────────────────────────────────
X_train_raw, X_test_raw, y_train, y_test = train_test_split(
    X.values, y, test_size=0.20, stratify=y, random_state=RANDOM_STATE
)
print(f"\nTrain: {X_train_raw.shape[0]} samples  |  Test: {X_test_raw.shape[0]} samples")

# ─────────────────────────────────────────────────────────────────────────────
# 3. YEO-JOHNSON POWER TRANSFORMATION  (Table 5.1 in report)
# ─────────────────────────────────────────────────────────────────────────────
print("\n[Step 3] Yeo-Johnson Power Transformation …")
power_tf = PowerTransformer(method="yeo-johnson", standardize=True)
X_train_yj = power_tf.fit_transform(X_train_raw)   # fit on train only
X_test_yj  = power_tf.transform(X_test_raw)

# Skewness check
sk_before = pd.DataFrame(X_train_raw).skew().abs().median()
sk_after  = pd.DataFrame(X_train_yj).skew().abs().median()
print(f"  Median |skewness| before: {sk_before:.3f}  →  after: {sk_after:.3f}")

# ─────────────────────────────────────────────────────────────────────────────
# 4. LASSO + RFECV FEATURE SELECTION  (Table 5.2 in report)
# ─────────────────────────────────────────────────────────────────────────────
print("\n[Step 4] LASSO + RFECV Feature Selection …")

# Stage 0: Variance filter
vt = VarianceThreshold(threshold=0.01)
X_train_vt = vt.fit_transform(X_train_yj)
X_test_vt  = vt.transform(X_test_yj)
print(f"  After variance filter: {X_train_vt.shape[1]} features")

# Stage 1: LassoCV coefficient screening
lasso_cv = LassoCV(cv=10, max_iter=5000, random_state=RANDOM_STATE, n_jobs=None)
lasso_cv.fit(X_train_vt, y_train)
lasso_mask = np.abs(lasso_cv.coef_) > 0
if lasso_mask.sum() < 5:
    lasso_mask = np.abs(lasso_cv.coef_) > np.percentile(np.abs(lasso_cv.coef_), 80)
X_train_lasso = X_train_vt[:, lasso_mask]
X_test_lasso  = X_test_vt[:, lasso_mask]
print(f"  After LASSO screening:  {X_train_lasso.shape[1]} features")

# Stage 2: RFECV with linear SVM estimator
svm_lin = SVC(kernel="linear", random_state=RANDOM_STATE)
rfecv = RFECV(
    estimator=svm_lin,
    step=max(1, X_train_lasso.shape[1] // 20),
    cv=StratifiedKFold(n_splits=5, shuffle=True, random_state=RANDOM_STATE),
    scoring="roc_auc",
    min_features_to_select=10,
    n_jobs=None,
)
rfecv.fit(X_train_lasso, y_train)
X_train_sel = rfecv.transform(X_train_lasso)
X_test_sel  = rfecv.transform(X_test_lasso)
n_selected  = X_train_sel.shape[1]
print(f"  After RFECV selection:  {n_selected} features  "
      f"(reduction: {X.shape[1]} → {n_selected}, "
      f"{100*(1 - n_selected/X.shape[1]):.0f}%)")

# Rebuild feature names for the selected subset
vt_support   = vt.get_support()
vt_names     = [feature_names_raw[i] for i, s in enumerate(vt_support) if s]
lasso_names  = [vt_names[i] for i, s in enumerate(lasso_mask) if s]
rfecv_support = rfecv.support_
selected_names = [lasso_names[i] for i, s in enumerate(rfecv_support) if s]
print(f"  Selected features: {selected_names[:5]} … (showing first 5)")

# ─────────────────────────────────────────────────────────────────────────────
# 5. BAYESIAN HYPERPARAMETER OPTIMISATION (Optuna)  (Section 5.4)
# ─────────────────────────────────────────────────────────────────────────────
print(f"\n[Step 5] Optuna Bayesian Optimisation ({MODEL_CHOICE}, {N_OPTUNA_TRIALS} trials) …")

cv_inner = StratifiedKFold(n_splits=5, shuffle=True, random_state=RANDOM_STATE)

def objective(trial: optuna.Trial) -> float:
    if MODEL_CHOICE == "svm_rbf":
        C     = trial.suggest_float("C",     1e-3, 1e3, log=True)
        gamma = trial.suggest_float("gamma", 1e-4, 10,  log=True)
        model = SVC(C=C, gamma=gamma, kernel="rbf",
                    probability=True, random_state=RANDOM_STATE)
    else:  # deep_mlp
        lr    = trial.suggest_float("learning_rate_init", 1e-5, 1e-2, log=True)
        alpha = trial.suggest_float("alpha",              1e-5, 1e-2, log=True)
        h     = trial.suggest_categorical("hidden_layer_sizes",
                                          [(256,128,64), (128,64,32),
                                           (256,128), (512,256,128,64)])
        model = MLPClassifier(
            hidden_layer_sizes=h, activation="relu",
            learning_rate_init=lr, alpha=alpha,
            max_iter=500, early_stopping=True,
            validation_fraction=0.1, random_state=RANDOM_STATE,
        )
    scores = cross_val_score(model, X_train_sel, y_train,
                             cv=cv_inner, scoring="roc_auc", n_jobs=None)
    return scores.mean()

study = optuna.create_study(
    direction="maximize",
    sampler=optuna.samplers.TPESampler(seed=RANDOM_STATE),
    pruner=optuna.pruners.HyperbandPruner(),
)
study.optimize(objective, n_trials=N_OPTUNA_TRIALS, show_progress_bar=False)
best_params = study.best_params
print(f"  Best params: {best_params}")
print(f"  Best CV AUC: {study.best_value:.4f}")

# ─────────────────────────────────────────────────────────────────────────────
# 6. FINAL MODEL + PLATT CALIBRATION  (Section 6.2 / 6.3)
# ─────────────────────────────────────────────────────────────────────────────
print("\n[Step 6] Training final calibrated model …")
if MODEL_CHOICE == "svm_rbf":
    base_model = SVC(
        C=best_params["C"], gamma=best_params["gamma"],
        kernel="rbf", probability=True, random_state=RANDOM_STATE,
    )
else:
    h = best_params.get("hidden_layer_sizes", (256,128,64))
    if isinstance(h, str):
        h = eval(h)
    base_model = MLPClassifier(
        hidden_layer_sizes=h, activation="relu",
        learning_rate_init=best_params.get("learning_rate_init", 1e-3),
        alpha=best_params.get("alpha", 1e-4),
        max_iter=500, early_stopping=True,
        validation_fraction=0.1, random_state=RANDOM_STATE,
    )

calibrated_model = CalibratedClassifierCV(base_model, cv=5, method="sigmoid")
calibrated_model.fit(X_train_sel, y_train)
print("  Model training complete.")

# ─────────────────────────────────────────────────────────────────────────────
# 7. EVALUATION  (Table 5.6 in report)
# ─────────────────────────────────────────────────────────────────────────────
print("\n[Step 7] Evaluation …")
probs = calibrated_model.predict_proba(X_test_sel)
preds = calibrated_model.predict(X_test_sel)

acc       = accuracy_score(y_test, preds)
auc_roc   = roc_auc_score(y_test, probs[:, 1])
precision = precision_score(y_test, preds, zero_division=0)
recall    = recall_score(y_test, preds, zero_division=0)
f1        = f1_score(y_test, preds, zero_division=0)
brier     = brier_score_loss(y_test, probs[:, 1])

print(f"\n  ┌{'─'*40}┐")
print(f"  │ {'Metric':<24} {'Value':>12}  │")
print(f"  ├{'─'*40}┤")
print(f"  │ {'Accuracy':<24} {acc:>12.4f}  │")
print(f"  │ {'AUC-ROC':<24} {auc_roc:>12.4f}  │")
print(f"  │ {'Precision (PD)':<24} {precision:>12.4f}  │")
print(f"  │ {'Recall (PD)':<24} {recall:>12.4f}  │")
print(f"  │ {'F1-Score (PD)':<24} {f1:>12.4f}  │")
print(f"  │ {'Brier Score':<24} {brier:>12.4f}  │")
print(f"  │ {'RFECV Features':<24} {n_selected:>12}  │")
print(f"  └{'─'*40}┘")
print(f"\n{classification_report(y_test, preds)}")

# ─────────────────────────────────────────────────────────────────────────────
# 8. CONFUSION MATRIX PLOT
# ─────────────────────────────────────────────────────────────────────────────
cm = confusion_matrix(y_test, preds)

fig_cm, ax_cm = plt.subplots(figsize=(5, 4.5))
ax_cm.imshow(cm, cmap="Blues")
ax_cm.set_xticks([0,1]); ax_cm.set_yticks([0,1])
ax_cm.set_xticklabels(["Healthy", "Parkinson's"]); ax_cm.set_yticklabels(["Healthy", "Parkinson's"])
ax_cm.set_xlabel("Predicted Label"); ax_cm.set_ylabel("Actual Label")
ax_cm.set_title("Confusion Matrix")
plt.colorbar(ax_cm.images[0], ax=ax_cm, fraction=0.046, pad=0.04)
for i in range(2):
    for j in range(2):
        ax_cm.text(j, i, str(cm[i, j]), ha="center", va="center",
                   fontsize=18, fontweight="bold",
                   color="white" if cm[i,j] > cm.max()/2 else "black")
fig_cm.tight_layout()
fig_cm.savefig("confusion_matrix.png", dpi=150, bbox_inches="tight")
plt.close(fig_cm)
print("\nConfusion matrix saved → confusion_matrix.png")

# ─────────────────────────────────────────────────────────────────────────────
# 9. ROC CURVE PLOT
# ─────────────────────────────────────────────────────────────────────────────
fpr, tpr, _ = roc_curve(y_test, probs[:, 1])

fig_roc, ax_roc = plt.subplots(figsize=(6, 5))
ax_roc.plot(fpr, tpr, lw=2.5, label=f"{MODEL_CHOICE.upper()} (AUC = {auc_roc:.4f})")
ax_roc.fill_between(fpr, tpr, alpha=0.10)
ax_roc.plot([0,1],[0,1], "k--", lw=1.2, label="Random")
ax_roc.set_xlabel("False Positive Rate"); ax_roc.set_ylabel("True Positive Rate")
ax_roc.set_title("ROC Curve")
ax_roc.legend(loc="lower right")
ax_roc.grid(True, alpha=0.3)
fig_roc.tight_layout()
fig_roc.savefig("roc_curve.png", dpi=150, bbox_inches="tight")
plt.close(fig_roc)
print("ROC curve saved → roc_curve.png")

# ─────────────────────────────────────────────────────────────────────────────
# 10. CALIBRATION CURVE
# ─────────────────────────────────────────────────────────────────────────────
prob_true, prob_pred = calibration_curve(y_test, probs[:, 1], n_bins=10)
fig_cal, ax_cal = plt.subplots(figsize=(5, 4))
ax_cal.plot(prob_pred, prob_true, "s-", label="Calibrated model")
ax_cal.plot([0,1],[0,1], "k--", label="Perfect calibration")
ax_cal.set_xlabel("Mean Predicted Probability"); ax_cal.set_ylabel("Fraction of Positives")
ax_cal.set_title("Calibration Curve")
ax_cal.legend(); ax_cal.grid(True, alpha=0.3)
fig_cal.tight_layout()
fig_cal.savefig("calibration_curve.png", dpi=150, bbox_inches="tight")
plt.close(fig_cal)
print("Calibration curve saved → calibration_curve.png")

# ─────────────────────────────────────────────────────────────────────────────
# 11. SHAP INTERPRETABILITY  (Section 5.5)
# ─────────────────────────────────────────────────────────────────────────────
print("\n[Step 11] Computing SHAP values (KernelExplainer) …")
try:
    background  = shap.kmeans(X_train_sel, min(50, X_train_sel.shape[0]))
    explainer   = shap.KernelExplainer(calibrated_model.predict_proba, background)
    n_explain   = min(80, X_test_sel.shape[0])
    shap_values = explainer.shap_values(X_test_sel[:n_explain], nsamples=100)

    # SHAP class-1 values
    if isinstance(shap_values, list):
        sv1 = shap_values[1]
    elif len(shap_values.shape) == 3:
        sv1 = shap_values[:, :, 1]
    else:
        sv1 = shap_values

    # ── Global beeswarm summary ──
    fig_bee, _ = plt.subplots(figsize=(10, 6))
    shap.summary_plot(sv1, X_test_sel[:n_explain],
                      feature_names=selected_names, show=False, plot_type="dot")
    plt.tight_layout()
    plt.savefig("shap_summary.png", dpi=150, bbox_inches="tight")
    plt.close()
    print("SHAP summary plot saved → shap_summary.png")

    # ── Bar plot ──
    fig_bar, _ = plt.subplots(figsize=(9, 5))
    shap.summary_plot(sv1, X_test_sel[:n_explain],
                      feature_names=selected_names, show=False,
                      plot_type="bar", max_display=15)
    plt.tight_layout()
    plt.savefig("shap_bar.png", dpi=150, bbox_inches="tight")
    plt.close()
    print("SHAP bar plot saved    → shap_bar.png")

    # ── Waterfall for patient 0 ──
    base_val = explainer.expected_value
    if isinstance(base_val, (list, np.ndarray)):
        base_val = base_val[1]
    explanation = shap.Explanation(
        values=sv1[0], base_values=base_val,
        data=X_test_sel[0], feature_names=selected_names,
    )
    fig_wf, _ = plt.subplots(figsize=(10, 6))
    shap.waterfall_plot(explanation, show=False, max_display=15)
    plt.tight_layout()
    plt.savefig("shap_waterfall_patient0.png", dpi=150, bbox_inches="tight")
    plt.close()
    print("SHAP waterfall saved   → shap_waterfall_patient0.png")

    # ── SHAP importance table ──
    shap_imp = pd.DataFrame({
        "Feature": selected_names,
        "Mean |SHAP|": np.abs(sv1).mean(axis=0),
    }).sort_values("Mean |SHAP|", ascending=False).reset_index(drop=True)
    shap_imp.index += 1
    print("\nTop 10 SHAP features:")
    print(shap_imp.head(10).to_string())

except Exception as exc:
    print(f"  SHAP computation skipped: {exc}")

# ─────────────────────────────────────────────────────────────────────────────
print("\n✅  Pipeline complete.")
print(f"   Model        : {MODEL_CHOICE}")
print(f"   Accuracy     : {acc:.4f}")
print(f"   AUC-ROC      : {auc_roc:.4f}")
print(f"   Brier Score  : {brier:.4f}")
print(f"   Features kept: {n_selected} / {X.shape[1]}")
